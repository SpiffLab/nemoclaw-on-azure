{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.42.1.51946",
      "templateHash": "10625727827519012660"
    }
  },
  "parameters": {
    "namePrefix": {
      "type": "string",
      "defaultValue": "nemoclaw",
      "minLength": 3,
      "maxLength": 16,
      "metadata": {
        "description": "Short prefix used for all resource names (3-16 chars, lowercase/alnum)."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "centralus",
      "metadata": {
        "description": "Azure region. Default reflects a region with current D-series capacity for this project; override as needed."
      }
    },
    "vmSize": {
      "type": "string",
      "defaultValue": "Standard_D4s_v4",
      "metadata": {
        "description": "VM size. Default is CPU-only for routed NVIDIA inference. Use an NC-series SKU for local GPU inference."
      }
    },
    "adminUsername": {
      "type": "string",
      "defaultValue": "azureuser",
      "metadata": {
        "description": "Admin username on the VM."
      }
    },
    "sshPublicKey": {
      "type": "securestring",
      "metadata": {
        "description": "SSH public key (full contents, e.g. ssh-ed25519 AAAA... user@host)."
      }
    },
    "allowedSshCidr": {
      "type": "string",
      "defaultValue": "0.0.0.0/0",
      "metadata": {
        "description": "CIDR allowed to reach port 22. Narrow this to your IP for production."
      }
    },
    "nvidiaApiKey": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "NVIDIA API key for routed inference. Leave empty to configure later."
      }
    },
    "assistantName": {
      "type": "string",
      "defaultValue": "my-assistant",
      "metadata": {
        "description": "Name of the NemoClaw assistant to onboard."
      }
    },
    "osDiskSizeGB": {
      "type": "int",
      "defaultValue": 64,
      "minValue": 30,
      "maxValue": 1024,
      "metadata": {
        "description": "OS disk size in GB (NemoClaw recommends 40+; default 64 leaves room for images)."
      }
    }
  },
  "variables": {
    "tags": {
      "project": "nemoclaw-on-azure",
      "workload": "nemoclaw",
      "managedBy": "bicep"
    }
  },
  "resources": [
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "network",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "namePrefix": {
            "value": "[parameters('namePrefix')]"
          },
          "location": {
            "value": "[parameters('location')]"
          },
          "allowedSshCidr": {
            "value": "[parameters('allowedSshCidr')]"
          },
          "tags": {
            "value": "[variables('tags')]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.42.1.51946",
              "templateHash": "11786007503777500437"
            }
          },
          "parameters": {
            "namePrefix": {
              "type": "string",
              "metadata": {
                "description": "Short prefix used for all resource names."
              }
            },
            "location": {
              "type": "string",
              "metadata": {
                "description": "Azure region."
              }
            },
            "allowedSshCidr": {
              "type": "string",
              "metadata": {
                "description": "CIDR allowed to reach port 22."
              }
            },
            "tags": {
              "type": "object",
              "metadata": {
                "description": "Tags applied to all resources."
              }
            }
          },
          "variables": {
            "suffix": "[uniqueString(resourceGroup().id, parameters('namePrefix'))]",
            "vnetName": "[format('{0}-vnet', parameters('namePrefix'))]",
            "subnetName": "default",
            "nsgName": "[format('{0}-nsg', parameters('namePrefix'))]",
            "pipName": "[format('{0}-pip-{1}', parameters('namePrefix'), variables('suffix'))]"
          },
          "resources": [
            {
              "type": "Microsoft.Network/networkSecurityGroups",
              "apiVersion": "2024-01-01",
              "name": "[variables('nsgName')]",
              "location": "[parameters('location')]",
              "tags": "[parameters('tags')]",
              "properties": {
                "securityRules": [
                  {
                    "name": "AllowSshInbound",
                    "properties": {
                      "priority": 1000,
                      "direction": "Inbound",
                      "access": "Allow",
                      "protocol": "Tcp",
                      "sourcePortRange": "*",
                      "destinationPortRange": "22",
                      "sourceAddressPrefix": "[parameters('allowedSshCidr')]",
                      "destinationAddressPrefix": "*"
                    }
                  }
                ]
              }
            },
            {
              "type": "Microsoft.Network/virtualNetworks",
              "apiVersion": "2024-01-01",
              "name": "[variables('vnetName')]",
              "location": "[parameters('location')]",
              "tags": "[parameters('tags')]",
              "properties": {
                "addressSpace": {
                  "addressPrefixes": [
                    "10.42.0.0/16"
                  ]
                }
              }
            },
            {
              "type": "Microsoft.Network/virtualNetworks/subnets",
              "apiVersion": "2024-01-01",
              "name": "[format('{0}/{1}', variables('vnetName'), variables('subnetName'))]",
              "properties": {
                "addressPrefix": "10.42.1.0/24",
                "networkSecurityGroup": {
                  "id": "[resourceId('Microsoft.Network/networkSecurityGroups', variables('nsgName'))]"
                }
              },
              "dependsOn": [
                "[resourceId('Microsoft.Network/networkSecurityGroups', variables('nsgName'))]",
                "[resourceId('Microsoft.Network/virtualNetworks', variables('vnetName'))]"
              ]
            },
            {
              "type": "Microsoft.Network/publicIPAddresses",
              "apiVersion": "2024-01-01",
              "name": "[variables('pipName')]",
              "location": "[parameters('location')]",
              "tags": "[parameters('tags')]",
              "sku": {
                "name": "Standard"
              },
              "properties": {
                "publicIPAllocationMethod": "Static",
                "publicIPAddressVersion": "IPv4",
                "idleTimeoutInMinutes": 4,
                "dnsSettings": {
                  "domainNameLabel": "[format('{0}-{1}', parameters('namePrefix'), variables('suffix'))]"
                }
              }
            }
          ],
          "outputs": {
            "subnetId": {
              "type": "string",
              "value": "[resourceId('Microsoft.Network/virtualNetworks/subnets', variables('vnetName'), variables('subnetName'))]"
            },
            "publicIpId": {
              "type": "string",
              "value": "[resourceId('Microsoft.Network/publicIPAddresses', variables('pipName'))]"
            },
            "publicIpAddress": {
              "type": "string",
              "value": "[reference(resourceId('Microsoft.Network/publicIPAddresses', variables('pipName')), '2024-01-01').ipAddress]"
            },
            "fqdn": {
              "type": "string",
              "value": "[reference(resourceId('Microsoft.Network/publicIPAddresses', variables('pipName')), '2024-01-01').dnsSettings.fqdn]"
            }
          }
        }
      }
    },
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "vm",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "namePrefix": {
            "value": "[parameters('namePrefix')]"
          },
          "location": {
            "value": "[parameters('location')]"
          },
          "vmSize": {
            "value": "[parameters('vmSize')]"
          },
          "adminUsername": {
            "value": "[parameters('adminUsername')]"
          },
          "sshPublicKey": {
            "value": "[parameters('sshPublicKey')]"
          },
          "subnetId": {
            "value": "[reference(resourceId('Microsoft.Resources/deployments', 'network'), '2025-04-01').outputs.subnetId.value]"
          },
          "publicIpId": {
            "value": "[reference(resourceId('Microsoft.Resources/deployments', 'network'), '2025-04-01').outputs.publicIpId.value]"
          },
          "nvidiaApiKey": {
            "value": "[parameters('nvidiaApiKey')]"
          },
          "assistantName": {
            "value": "[parameters('assistantName')]"
          },
          "osDiskSizeGB": {
            "value": "[parameters('osDiskSizeGB')]"
          },
          "tags": {
            "value": "[variables('tags')]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.42.1.51946",
              "templateHash": "16415970210130912875"
            }
          },
          "parameters": {
            "namePrefix": {
              "type": "string",
              "metadata": {
                "description": "Short prefix used for resource names."
              }
            },
            "location": {
              "type": "string",
              "metadata": {
                "description": "Azure region."
              }
            },
            "vmSize": {
              "type": "string",
              "metadata": {
                "description": "VM size."
              }
            },
            "adminUsername": {
              "type": "string",
              "metadata": {
                "description": "Admin username."
              }
            },
            "sshPublicKey": {
              "type": "securestring",
              "metadata": {
                "description": "SSH public key (contents)."
              }
            },
            "subnetId": {
              "type": "string",
              "metadata": {
                "description": "Subnet resource ID."
              }
            },
            "publicIpId": {
              "type": "string",
              "metadata": {
                "description": "Public IP resource ID."
              }
            },
            "nvidiaApiKey": {
              "type": "securestring",
              "metadata": {
                "description": "NVIDIA API key for routed inference. Empty = configure later."
              }
            },
            "assistantName": {
              "type": "string",
              "metadata": {
                "description": "NemoClaw assistant name to onboard."
              }
            },
            "osDiskSizeGB": {
              "type": "int",
              "metadata": {
                "description": "OS disk size in GB."
              }
            },
            "tags": {
              "type": "object",
              "metadata": {
                "description": "Tags."
              }
            }
          },
          "variables": {
            "vmName": "[format('{0}-vm', parameters('namePrefix'))]",
            "nicName": "[format('{0}-nic', parameters('namePrefix'))]",
            "cloudInitTemplate": "#cloud-config\r\n# NemoClaw on Azure — first-boot provisioning\r\n# Installs Docker + Node 22 (via nvm) + NemoClaw, then runs `nemoclaw onboard`.\r\n# Placeholders __ADMIN_USERNAME__, __NVIDIA_API_KEY__, __ASSISTANT_NAME__ are\r\n# substituted at deployment time by infra/modules/vm.bicep.\r\n\r\npackage_update: true\r\npackage_upgrade: false\r\n\r\npackages:\r\n  - ca-certificates\r\n  - curl\r\n  - git\r\n  - gnupg\r\n  - jq\r\n  - lsb-release\r\n  - uidmap\r\n\r\nwrite_files:\r\n  - path: /etc/profile.d/nemoclaw.sh\r\n    permissions: '0644'\r\n    content: |\r\n      # Loaded for interactive shells so `nemoclaw` / `openclaw` are on PATH.\r\n      export NVM_DIR=\"$HOME/.nvm\"\r\n      [ -s \"$NVM_DIR/nvm.sh\" ] && . \"$NVM_DIR/nvm.sh\"\r\n\r\n  - path: /usr/local/sbin/nemoclaw-bootstrap.sh\r\n    permissions: '0755'\r\n    content: |\r\n      #!/usr/bin/env bash\r\n      # Runs as the admin user via runcmd. Installs Node/NemoClaw and onboards.\r\n      # The upstream installer requires a TTY for EULA acceptance when run\r\n      # interactively; we pass NEMOCLAW_NON_INTERACTIVE=1 and\r\n      # --yes-i-accept-third-party-software so it works under cloud-init.\r\n      set -euo pipefail\r\n\r\n      LOG=/var/log/nemoclaw-bootstrap.log\r\n      # Log file is created by runcmd (root) and chowned to the admin user\r\n      # before this script is invoked, so the tee append works.\r\n      exec > >(tee -a \"$LOG\") 2>&1\r\n      echo \"[nemoclaw] bootstrap started $(date -Is)\"\r\n\r\n      export HOME=\"/home/__ADMIN_USERNAME__\"\r\n      cd \"$HOME\"\r\n\r\n      # 1. Wait for Docker to be ready.\r\n      for i in {1..60}; do\r\n        if docker info >/dev/null 2>&1; then break; fi\r\n        sleep 2\r\n      done\r\n\r\n      # 2. Install nvm + Node 22 (NemoClaw needs Node >=22.16, npm >=10).\r\n      if [ ! -d \"$HOME/.nvm\" ]; then\r\n        curl -fsSL https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.1/install.sh | bash\r\n      fi\r\n      export NVM_DIR=\"$HOME/.nvm\"\r\n      # shellcheck disable=SC1091\r\n      . \"$NVM_DIR/nvm.sh\"\r\n      nvm install 22\r\n      nvm alias default 22\r\n      node --version\r\n      npm --version\r\n\r\n      # 3. Export NVIDIA API key for the installer (if provided at deploy time).\r\n      if [ -n \"__NVIDIA_API_KEY__\" ]; then\r\n        export NVIDIA_API_KEY=\"__NVIDIA_API_KEY__\"\r\n        # Persist for future shells (quoted to survive special chars in keys).\r\n        grep -q '^export NVIDIA_API_KEY=' \"$HOME/.bashrc\" || \\\r\n          printf 'export NVIDIA_API_KEY=%q\\n' \"__NVIDIA_API_KEY__\" >> \"$HOME/.bashrc\"\r\n      fi\r\n\r\n      # 4. Run the official NemoClaw installer. NEMOCLAW_NON_INTERACTIVE=1 and\r\n      #    --yes-i-accept-third-party-software are required for cloud-init\r\n      #    (no TTY for the EULA prompt; otherwise the installer aborts).\r\n      export NEMOCLAW_NON_INTERACTIVE=1\r\n      export PATH=\"$HOME/.local/bin:$PATH\"\r\n      curl -fsSL https://www.nvidia.com/nemoclaw.sh -o /tmp/nemoclaw-installer.sh\r\n      bash /tmp/nemoclaw-installer.sh --yes-i-accept-third-party-software || {\r\n        echo \"[nemoclaw] installer failed; see $LOG\" >&2\r\n        exit 1\r\n      }\r\n\r\n      # 5. Sanity-check PATH for future SSH sessions.\r\n      . \"$NVM_DIR/nvm.sh\"\r\n      if command -v nemoclaw >/dev/null 2>&1; then\r\n        nemoclaw --version || true\r\n        nemoclaw \"__ASSISTANT_NAME__\" status || true\r\n      fi\r\n\r\n      echo \"[nemoclaw] bootstrap finished $(date -Is)\"\r\n\r\nruncmd:\r\n  # --- Ubuntu 24.04: ensure /run/sshd exists. The openssh-server tmpfiles.d\r\n  #     rule sometimes races with cloud-init on first boot, leaving sshd\r\n  #     unable to start (\"Missing privilege separation directory: /run/sshd\").\r\n  #     Socket activation silently closes incoming SSH until this is fixed.\r\n  - [ mkdir, -p, /run/sshd ]\r\n  - [ chmod, '0755', /run/sshd ]\r\n  - [ bash, -lc, 'systemctl restart ssh.socket 2>/dev/null || systemctl restart ssh.service' ]\r\n\r\n  # --- Pre-create the bootstrap log so the admin-user script can append. ---\r\n  - [ bash, -lc, 'touch /var/log/nemoclaw-bootstrap.log && chown __ADMIN_USERNAME__:__ADMIN_USERNAME__ /var/log/nemoclaw-bootstrap.log' ]\r\n\r\n  # --- Docker Engine (official get.docker.com) ---\r\n  - [ bash, -lc, 'curl -fsSL https://get.docker.com | sh' ]\r\n  - [ systemctl, enable, --now, docker ]\r\n  - [ usermod, -aG, docker, __ADMIN_USERNAME__ ]\r\n\r\n  # --- NemoClaw bootstrap, running as the admin user ---\r\n  - [ bash, -lc, 'sudo -u __ADMIN_USERNAME__ -H /usr/local/sbin/nemoclaw-bootstrap.sh' ]\r\n\r\nfinal_message: \"NemoClaw provisioning finished. See /var/log/nemoclaw-bootstrap.log and /var/log/cloud-init-output.log.\"\r\n",
            "cloudInitRendered": "[replace(replace(replace(variables('cloudInitTemplate'), '__ADMIN_USERNAME__', parameters('adminUsername')), '__NVIDIA_API_KEY__', parameters('nvidiaApiKey')), '__ASSISTANT_NAME__', parameters('assistantName'))]"
          },
          "resources": [
            {
              "type": "Microsoft.Network/networkInterfaces",
              "apiVersion": "2024-01-01",
              "name": "[variables('nicName')]",
              "location": "[parameters('location')]",
              "tags": "[parameters('tags')]",
              "properties": {
                "ipConfigurations": [
                  {
                    "name": "ipconfig1",
                    "properties": {
                      "subnet": {
                        "id": "[parameters('subnetId')]"
                      },
                      "publicIPAddress": {
                        "id": "[parameters('publicIpId')]"
                      },
                      "privateIPAllocationMethod": "Dynamic"
                    }
                  }
                ]
              }
            },
            {
              "type": "Microsoft.Compute/virtualMachines",
              "apiVersion": "2024-07-01",
              "name": "[variables('vmName')]",
              "location": "[parameters('location')]",
              "tags": "[parameters('tags')]",
              "properties": {
                "hardwareProfile": {
                  "vmSize": "[parameters('vmSize')]"
                },
                "storageProfile": {
                  "imageReference": {
                    "publisher": "Canonical",
                    "offer": "ubuntu-24_04-lts",
                    "sku": "server",
                    "version": "latest"
                  },
                  "osDisk": {
                    "createOption": "FromImage",
                    "diskSizeGB": "[parameters('osDiskSizeGB')]",
                    "managedDisk": {
                      "storageAccountType": "Premium_LRS"
                    }
                  }
                },
                "osProfile": {
                  "computerName": "[variables('vmName')]",
                  "adminUsername": "[parameters('adminUsername')]",
                  "customData": "[base64(variables('cloudInitRendered'))]",
                  "linuxConfiguration": {
                    "disablePasswordAuthentication": true,
                    "ssh": {
                      "publicKeys": [
                        {
                          "path": "[format('/home/{0}/.ssh/authorized_keys', parameters('adminUsername'))]",
                          "keyData": "[parameters('sshPublicKey')]"
                        }
                      ]
                    }
                  }
                },
                "networkProfile": {
                  "networkInterfaces": [
                    {
                      "id": "[resourceId('Microsoft.Network/networkInterfaces', variables('nicName'))]"
                    }
                  ]
                }
              },
              "dependsOn": [
                "[resourceId('Microsoft.Network/networkInterfaces', variables('nicName'))]"
              ]
            }
          ],
          "outputs": {
            "vmName": {
              "type": "string",
              "value": "[variables('vmName')]"
            },
            "vmId": {
              "type": "string",
              "value": "[resourceId('Microsoft.Compute/virtualMachines', variables('vmName'))]"
            }
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Resources/deployments', 'network')]"
      ]
    }
  ],
  "outputs": {
    "publicIpAddress": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'network'), '2025-04-01').outputs.publicIpAddress.value]"
    },
    "sshCommand": {
      "type": "string",
      "value": "[format('ssh {0}@{1}', parameters('adminUsername'), reference(resourceId('Microsoft.Resources/deployments', 'network'), '2025-04-01').outputs.publicIpAddress.value)]"
    },
    "vmName": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'vm'), '2025-04-01').outputs.vmName.value]"
    }
  }
